# 
def analyze_resume(resume_text):

    missing_sections = []
    skills_found = []

    sections = ["education", "skills", "projects", "experience"]
    technical_skills = ["python", "java", "c++", "machine learning", "sql", "data science"]

    # Check sections
    for section in sections:
        if section not in resume_text.lower():
            missing_sections.append(section)

    # Check skills
    for skill in technical_skills:
        if skill in resume_text.lower():
            skills_found.append(skill)

    # Resume length check
    words = resume_text.split()
    if len(words) < 40:
        length_feedback = "Resume is too short. Add more details."
    elif len(words) > 500:
        length_feedback = "Resume is too long. Try to shorten it."
    else:
        length_feedback = "Resume length looks good."

    # Score calculation
    score = 0
    score += (4 - len(missing_sections)) * 10
    score += len(skills_found) * 5

    if 40 <= len(words) <= 500:
        score += 20

    # Suggestions
    suggestions = []

    for section in missing_sections:
        suggestions.append(f"Add {section} section to your resume.")

    if len(skills_found) < 3:
        suggestions.append("Add more technical skills to strengthen your resume.")

    return skills_found, missing_sections, length_feedback, score, suggestions


def main():

    print("===== AI Resume Analyzer =====")

    print("\nEnter your resume details below:")

    name = input("Name: ")
    email = input("Email: ")
    phone = input("Phone: ")
    education = input("Education: ")
    skills = input("Skills: ")
    projects = input("Projects: ")
    experience = input("Experience: ")

    resume_text = f"""
    Name: {name}
    Email: {email}
    Phone: {phone}

    Education:
    {education}

    Skills:
    {skills}

    Projects:
    {projects}

    Experience:
    {experience}
    """

    print("\nAnalyzing resume...\n")

    skills_found, missing_sections, length_feedback, score, suggestions = analyze_resume(resume_text)

    print("===== Analysis Result =====")

    print("\nSkills Detected:")
    print(skills_found if skills_found else "No technical skills detected.")

    print("\nMissing Sections:")
    print(missing_sections if missing_sections else "None")

    print("\nLength Check:")
    print(length_feedback)

    print("\nResume Score:", score, "/ 100")

    print("\nSuggestions:")
    if suggestions:
        for i, suggestion in enumerate(suggestions, 1):
            print(f"{i}. {suggestion}")
    else:
        print("Your resume looks strong!")


if __name__== "__main__":
    main()
